{
  "name": "gardenops-frontend",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "check:xss-sinks": "python3 ../scripts/check_innerhtml_sinks.py --root src --allowlist security/innerhtml_allowlist.txt",
    "check:invite-token": "node ../scripts/check_invite_token_hash_only.cjs",
    "check:auth-gate-status": "node ../scripts/check_auth_gate_status_flow.cjs",
    "perf:page": "node ../scripts/check_page_performance.cjs",
    "check:no-sourcemaps": "node ../scripts/check_no_sourcemaps.cjs dist",
    "check:dist-assets": "node ../scripts/check_frontend_dist_assets.cjs dist",
    "typecheck": "tsc --noEmit",
    "build": "npm run check:xss-sinks && npm run check:invite-token && npm run check:auth-gate-status && tsc --noEmit && vite build && npm run check:no-sourcemaps && npm run check:dist-assets",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@types/leaflet": "^1.9.21",
    "playwright-core": "1.61.0",
    "typescript": "6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/list": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "leaflet": "^1.9.4"
  }
}
