APP_ENV=development
INTERNET_EXPOSED=false
AUTH_REQUIRED=false
AUTH_MODE=session

DATABASE_URL=postgresql://gardenops:change-me@127.0.0.1:5432/gardenops

APP_NAME=GardenOps
APP_SLUG=gardenops
VITE_APP_NAME=GardenOps
VITE_APP_SLUG=gardenops

ALLOWED_HOSTS=localhost,127.0.0.1,[::1],::1,testserver
CORS_ALLOW_ORIGINS=http://localhost:5173
TRUST_PROXY_HEADERS=false

RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_PREFIX=gardenops:ratelimit

AUTH_API_KEY=change-me
AUTH_BOOTSTRAP_USERNAME=
AUTH_BOOTSTRAP_PASSWORD=
AUTH_BOOTSTRAP_ROLE=admin
AUTH_MFA_SECRET_KEY=change-me

AI_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_FAST_MODEL=gpt-5.4-mini
PLANTNET_API_KEY=

