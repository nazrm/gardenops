# Dedicated local test environment.
# Copy to .env.test.local, edit credentials locally, and never commit that file.

APP_ENV=test
AUTH_REQUIRED=false
INTERNET_EXPOSED=false
RATE_LIMIT_BACKEND=memory
AUTH_PASSWORD_HASH_FAST_FOR_TESTS=true
ALLOWED_HOSTS=localhost,127.0.0.1,[::1],::1,testserver,testclient
CORS_ALLOW_ORIGINS=http://localhost:5173

# Must point at a disposable database. Tests run migrations and can truncate data.
DATABASE_URL=postgresql://gardenops:change-me@127.0.0.1:5432/gardenops_test
GARDENOPS_TEST_POSTGRES_URL=postgresql://gardenops:change-me@127.0.0.1:5432/gardenops_test

GARDENOPS_LOGS_DIR=/tmp/gardenops-test-logs
MEDIA_STORAGE_DIR=/tmp/gardenops-test-media
